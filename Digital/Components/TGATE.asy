Version 4
SymbolType CELL
RECTANGLE Normal -80 -72 80 72
WINDOW 0 0 -72 Bottom 2
SYMATTR SpiceLine L=0.28u Wn=1u Wp=3u M=1
PIN -80 -48 LEFT 8
PINATTR PinName A
PINATTR SpiceOrder 1
PIN -80 48 LEFT 8
PINATTR PinName A_bar
PINATTR SpiceOrder 2
PIN -80 0 LEFT 8
PINATTR PinName IN
PINATTR SpiceOrder 3
PIN 80 -48 RIGHT 8
PINATTR PinName Vdd
PINATTR SpiceOrder 4
PIN 80 0 RIGHT 8
PINATTR PinName OUT
PINATTR SpiceOrder 5
