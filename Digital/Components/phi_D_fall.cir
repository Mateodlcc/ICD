XX1 Xold_0 Xold_1 Xold_2 Xold_3 Xold_4 Xold_5 0 0 Xnew_0 Xnew_1 Xnew_2 Xnew_3 Xnew_4 Xnew_5 0 0 Vdd Vdd NC_01 S1_0 phi2_0 phi2_1 phi2_2 phi2_3 phi2_4 phi2_5 S1_7 cla-8bit
XX2 S1_0 phi2_0 phi2_1 phi2_2 phi2_3 phi2_4 phi2_5 S1_7 0 Xold_0 Xold_1 Xold_2 Xold_3 Xold_4 Xold_5 0 Vdd Vdd NC_02 S2_0 S2_1 phi1_0 phi1_1 phi1_2 phi1_3 phi1_4 phi1_5 cla-8bit
XX3 S1_0 phi2_0 phi2_1 phi2_2 phi2_3 phi2_4 phi2_5 S1_7 0 Xnew_0 Xnew_1 Xnew_2 Xnew_3 Xnew_4 Xnew_5 0 Vdd Vdd NC_03 S3_0 S3_1 phi3_0 phi3_1 phi3_2 phi3_3 phi3_4 phi3_5 cla-8bit
.ends fir_cla

.subckt invx1 A Vdd X Vee
M1 X A Vee Vee nmos_3p3 l={L} w={Wn}
M2 Vdd A X Vdd pmos_3p3 l={L} w={Wp}
.param Wp=3u Wn=1u L=0.28u
.ends invx1

.subckt tgate A A_bar IN Vdd OUT
M1 IN A OUT 0 nmos_3p3 l='L' w='Wn' m='M'
M2 OUT A_bar IN Vdd pmos_3p3 l='L' w='Wp' m='M'
.param L=0.28u Wn=1u Wp=2u M=1
.ends tgate

.subckt cla-8bit A_0 A_1 A_2 A_3 A_4 A_5 A_6 A_7 B_0 B_1 B_2 B_3 B_4 B_5 B_6 B_7 Cin Vdd Cout S0 S1 S2 S3 S4 S5 S6 S7
XX1 A_0 A_1 A_2 A_3 B_0 B_1 B_2 B_3 Cin Vdd 0 N001 S0 S1 S2 S3 cla-4bit
XX2 A_4 A_5 A_6 A_7 B_4 B_5 B_6 B_7 N001 Vdd 0 Cout S4 S5 S6 S7 cla-4bit
.ends cla-8bit

.subckt cla-4bit A_0 A_1 A_2 A_3 B_0 B_1 B_2 B_3 Cin Vdd Vee Co_3 S0 S1 S2 S3
XX32 N002 Vdd N003 Vee invx1
XX33 N006 Vdd Co_0 Vee invx1
