XX8 N003 Vdd X Vee invx1
XX9 N005 Vdd N004 Vee invx1
XX10 A B Vdd Vee N001 nor2x1
XX11 C D Vdd Vee N005 nor2x1
XX12 N002 N004 Vdd Vee N003 nor2x1
.ends 4-nor

.subckt 3-nor A B C Vdd Vee X
XX1 A B Vdd Vee N001 nor2x1
XX3 N002 C Vdd Vee N003 nor2x1
XX5 N001 Vdd N002 Vee invx1
XX8 N003 Vdd X Vee invx1
.ends 3-nor

.subckt 3-nand A B C Vdd Vee X
XX3 N003 Vdd X Vee invx1
XX4 N001 Vdd N002 Vee invx1
XX7 A B Vdd N001 Vee nand2x1
XX8 N002 C Vdd N003 Vee nand2x1
.ends 3-nand

.subckt 4-nand A B C D Vdd Vee X
XX7 A B Vdd N001 Vee nand2x1
XX8 C D Vdd N005 Vee nand2x1
XX9 N002 N004 Vdd N003 Vee nand2x1
XX10 N001 Vdd N002 Vee invx1
XX11 N005 Vdd N004 Vee invx1
XX12 N003 Vdd X Vee invx1
.ends 4-nand

.subckt 5-nand A B C D E Vdd Vee X
XX1 N001 E Vdd N002 Vee nand2x1
XX2 N002 Vdd X Vee invx1
XX3 A B C D Vdd Vee N001 4-nand
.ends 5-nand

.subckt pg A B Vdd Vee G P
XX5 A B Vdd Vee N001 xnor2x1
XX6 A B Vdd N002 Vee nand2x1
XX7 N002 Vdd G Vee invx1
XX8 N001 Vdd P Vee invx1
.ends pg

.model NMOS NMOS
.model PMOS PMOS
.lib "C:\Users\Vicente\AppData\Local\LTspice\lib\cmp\standard.mos"
.param Xnew_0=0 Xnew_1=0 Xnew_2=0 Xnew_3=0 Xnew_4=0 Xnew_5=3.3
.tran 0 10n 0 10p
.inc "C:\Users\Vicente\Desktop\UC\Semestre 11\Proyectos\ICD\gf180\cmos_tt.txt"
* Scenario A: x_old 011111->100000, x_new 100000. phi1: 31->32, phi1_5 rises.
* Scenario B: x_old 000000->000001, x_new 111101. phi1: 15->16, phi1_4 rises.
* Scenario C: x_old 111110->111111, x_new 000001. phi1: 47->48, phi1_4 rises.
* Scenario D: x_old 100000->011111, x_new 100000. phi1: 32->31, phi1_5 falls.
.measure tran tdelay TRIG V(xold_5) VAL=1.65 FALL=1 TARG V(phi1_5) VAL=1.65 FALL=1
.backanno
.end