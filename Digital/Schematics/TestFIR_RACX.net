V2 S0 P_0 0
.ends pseudo-cla-4bit-nocin

.subckt 2x1_mux A Vdd X0 X1 Y
XX2 A A_BAR X0 Vdd Y tgate params: L=0.28u Wn=1u Wp=3u M=1
XX3 A Vdd A_BAR 0 invx1
XX4 A_BAR A X1 Vdd Y tgate params: L=0.28u Wn=1u Wp=3u M=1
.ends 2x1_mux

.subckt dff CK D Vdd Q Q_BAR
XX5 D Vdd N001 0 invx1
XX2 N002 Vdd N003 0 invx1
XX3 N003 Vdd N005 0 invx1
XX4 CK CK_BAR N005 Vdd N002 tgate params: L=0.28u Wn={Wn} Wp={Wp} M=1
XX6 CK CK_BAR N003 Vdd N004 tgate params: L=0.28u Wn={Wn} Wp={Wp} M=1
XX7 N004 Vdd Q_BAR 0 invx1
XX8 Q_BAR Vdd N006 0 invx1
XX9 CK_BAR CK N006 Vdd N004 tgate params: L=0.28u Wn={Wn} Wp={Wp} M=1
XX10 Q_BAR Vdd Q 0 invx1
XX11 CK Vdd CK_BAR 0 invx1
XX1 CK_BAR CK N001 Vdd N002 tgate params: L=0.28u Wn={Wn} Wp={Wp} M=1
.param Wp=3u Wn=1u
.ends dff

.subckt tgate A A_bar IN Vdd OUT
M1 IN A OUT 0 nmos_3p3 l='L' w='Wn' m='M'
M2 OUT A_bar IN Vdd pmos_3p3 l='L' w='Wp' m='M'
.param L=0.28u Wn=1u Wp=3u M=1
.ends tgate

.subckt xnor2x1 A B Vdd Vee X
M1 X B A Vee nmos_3p3 l={L} w={Wn }
M3 A N001 X Vdd pmos_3p3 l={L} w={Wp}
XX1 B Vdd N001 Vee invx1
XX2 A Vdd N002 Vee invx1
M2 X N001 N002 Vee nmos_3p3 l={L} w={Wn}
M4 N002 B X Vdd pmos_3p3 l={L} w={Wp}
.param Wp=3u Wn=1u L=0.28u
.ends xnor2x1

.subckt pg A B Vdd Vee G P
XX5 A B Vdd Vee N001 xnor2x1
XX6 A B Vdd N002 Vee nand2x1
XX7 N002 Vdd G Vee invx1
XX8 N001 Vdd P Vee invx1
.ends pg

.subckt 3-nand A B C Vdd Vee X
XX3 N003 Vdd X Vee invx1
XX4 N001 Vdd N002 Vee invx1
XX7 A B Vdd N001 Vee nand2x1
XX8 N002 C Vdd N003 Vee nand2x1
.ends 3-nand

.subckt 4-nand A B C D Vdd Vee X
XX7 A B Vdd N001 Vee nand2x1
XX8 C D Vdd N005 Vee nand2x1
XX9 N002 N004 Vdd N003 Vee nand2x1
XX10 N001 Vdd N002 Vee invx1
XX11 N005 Vdd N004 Vee invx1
XX12 N003 Vdd X Vee invx1
.ends 4-nand

.subckt 5-nand A B C D E Vdd Vee X
XX1 N001 E Vdd N002 Vee nand2x1
XX2 N002 Vdd X Vee invx1
XX4 A B C D Vdd Vee N001 4-nand
.ends 5-nand

.subckt pseudonor-2 A B Vdd Vee X
M3 X B Vee Vee nmos_3p3 l={L} w={Wn}
M1 Vdd Vee X Vdd pmos_3p3 l={L} w={Wp}
M2 X A Vee Vee nmos_3p3 l={L} w={Wn}
.param L=0.28u Wn=1u Wp={a*Wn}
.ends pseudonor-2

.subckt pseudonor-4 A B C D Vdd Vee X
M3 X B Vee Vee nmos_3p3 l={L} w={Wn}
M1 Vdd Vee X Vdd pmos_3p3 l={L} w={Wp}
M2 X A Vee Vee nmos_3p3 l={L} w={Wn}
M4 X C Vee Vee nmos_3p3 l={L} w={Wn}
M5 X D Vee Vee nmos_3p3 l={L} w={Wn}
.param L=0.28u Wn=1u Wp={a*Wn}
.ends pseudonor-4

.subckt pseudonor-5 A B C D E Vdd Vee X
M3 X B Vee Vee nmos_3p3 l={L} w={Wn}
M1 Vdd Vee X Vdd pmos_3p3 l={L} w={Wp}
M2 X A Vee Vee nmos_3p3 l={L} w={Wn}
M4 X C Vee Vee nmos_3p3 l={L} w={Wn}
M5 X D Vee Vee nmos_3p3 l={L} w={Wn}
M6 X E Vee Vee nmos_3p3 l={L} w={Wn}
.param L=0.28u Wn=1u Wp={a*Wn}
.ends pseudonor-5

.subckt pseudonor-3 A B C Vdd Vee X
M3 X B Vee Vee nmos_3p3 l={L} w={Wn}
M1 Vdd Vee X Vdd pmos_3p3 l={L} w={Wp}
M2 X A Vee Vee nmos_3p3 l={L} w={Wn}
M4 X C Vee Vee nmos_3p3 l={L} w={Wn}
.param L=0.28u Wn=1u Wp={a*Wn}
.ends pseudonor-3

.model NMOS NMOS
.model PMOS PMOS
.lib C:\Users\Vicente\AppData\Local\LTspice\lib\cmp\standard.mos
.param Xold_0=0 Xold_1=0 Xold_2=0 Xold_3=0 Xold_4=0 Xold_5=0
.param Xnew_0=0 Xnew_1=0 Xnew_2=0 Xnew_3=0 Xnew_4=0 Xnew_5=0
* .tran 0 100n 0 10p
.inc ..\..\gf180\cmos_tt.txt
.measure tran tphi1_A TRIG V(xold_5) VAL=1.65 RISE=1 TARG V(phi1_5) VAL=1.65 RISE=1
.measure tran tphi1_B TRIG V(Xold_0) VAL=1.65 RISE=1 TARG V(phi1_4) VAL=1.65 RISE=1
.param a=0.9
* (0.25*V(phi0_0) + 0.5*V(phi0_1) + V(phi0_2) + 2*V(phi0_3) + 4*V(phi0_4) + 8*V(phi0_5))/3.3\n(0.25*V(phi1_0) + 0.5*V(phi1_1) + V(phi1_2) + 2*V(phi1_3) + 4*V(phi1_4) + 8*V(phi1_5))/3.3\n(0.25*V(phi2_0) + 0.5*V(phi2_1) + V(phi2_2) + 2*V(phi2_3) + 4*V(phi2_4) + 8*V(phi2_5))/3.3\n(0.25*V(phi3_0) + 0.5*V(phi3_1) + V(phi3_2) + 2*V(phi3_3) + 4*V(phi3_4) + 8*V(phi3_5))/3.3
* (0.25*V(y0)+0.5*V(y1)+V(y2)+2*V(y3)+4*V(y4)+8*V(y5))/3.3
.tran {100*t_oc}
.param f_oc = 1.8G
.param t_oc = {1/f_oc}
.param tclk = {t_oc}
.param td = {t_oc/5}
.param tt = 10p
.ic V(phi0_0)=0 V(phi0_1)=0 V(phi0_2)=0 V(phi0_3)=0 V(phi0_4)=0 V(phi0_5)=0
.meas TRAN Pvdd AVG V(Vdd)*I(V13)     FROM={50*tclk} TO={70*tclk}
.meas TRAN Pclk AVG V(ck_fast)*I(V17) FROM={50*tclk} TO={70*tclk}
.meas TRAN Ptot AVG Pclk+Pvdd         FROM={50*tclk} TO={70*tclk}
.backanno
.end
