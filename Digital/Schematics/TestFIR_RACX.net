* C:\Users\Vicente\Desktop\UC\Semestre 11\Proyectos\ICD\Digital\Schematics\TestFIR_RACX.asc
V1 Xnew_0 0 PULSE(0 3.3 5n 100p 100p 500n 1000n 1)
V2 Xnew_1 0 PULSE(0 0 5n 100p 100p 50n 100n 1)
V3 Xnew_2 0 PULSE(0 0 5n 100p 100p 50n 100n 1)
V4 Xnew_3 0 PULSE(0 0 5n 100p 100p 50n 100n 1)
V5 Xnew_4 0 PULSE(0 0 5n 100p 100p 50n 100n 1)
V6 Xnew_5 0 PULSE(0 0 5n 100p 100p 50n 100n 1)
V7 Xold_0 0 {Xnew_0}
V8 Xold_1 0 {Xnew_1}
V9 Xold_2 0 {Xnew_2}
V10 Xold_3 0 {Xnew_3}
V11 Xold_4 0 {Xnew_4}
V12 Xold_5 0 {Xnew_5}
V13 Vdd 0 3.3
XX2 N001 q0_0 q0_1 q0_2 q0_3 q0_4 q0_5 N002 q1_0 q1_1 q1_2 q1_3 q1_4 q1_5 N003 q2_0 q2_1 q2_2 q2_3 q2_4 q2_5 N004 q3_0 q3_1 q3_2 q3_3 q3_4 q3_5 Vdd y0_ff y1_ff y2_ff y3_ff y4_ff y5_ff 24x6muc
XX3 q0 q1 vdd N001 N002 N003 N004 decoder
XX8 ck_fast vdd q0 q1 2bcount
V17 ck_fast 0 PULSE(0 3.3 'td' 'tt' 'tt' 'tclk/2' 'tclk')
V19 i_clk 0 PULSE(0 3.3 'td' 'tt' 'tt' '4*tclk/2' '4*tclk')
V20 i_rstb 0 PULSE(3.3 0 1n 'tt' 'tt' 10n)
XA1 i_clk i_rstb o_D[1] o_D[0] o_D[5] o_D[4] o_D[3] o_D[2] ramp
XX1 Vdd 0 oc_0 oc_1 oc_2 oc_3 q0_2 q0_3 q0_4 q0_5 phi0_0 phi0_1 phi0_2 phi0_3 phi0_4 phi0_5 phi1_0 phi1_1 phi1_2 phi1_3 phi1_4 phi1_5 phi2_0 phi2_1 phi2_2 phi2_3 phi2_4 phi2_5 phi3_0 phi3_1 phi3_2 phi3_3 phi3_4 phi3_5 pseudo_fir_cla_nocin
XX11 ck_fast N005 N006 N007 N008 N009 N010 y0 y1 y2 y3 y4 y5 dff_ideal_5
XX10 q0 q1 Vdd N011 0 nand2x1
XX4 ck_fast phi0_0 phi0_1 phi0_2 phi0_3 phi0_4 phi0_5 EN Vdd q0_0 q0_1 q0_2 q0_3 q0_4 q0_5 sdff_5_en
XX5 ck_fast phi1_0 phi1_1 phi1_2 phi1_3 phi1_4 phi1_5 EN Vdd q1_0 q1_1 q1_2 q1_3 q1_4 q1_5 sdff_5_en
XX6 ck_fast phi2_0 phi2_1 phi2_2 phi2_3 phi2_4 phi2_5 EN Vdd q2_0 q2_1 q2_2 q2_3 q2_4 q2_5 sdff_5_en
XX7 ck_fast phi3_0 phi3_1 phi3_2 phi3_3 phi3_4 phi3_5 EN Vdd q3_0 q3_1 q3_2 q3_3 q3_4 q3_5 sdff_5_en
XX9 ck_fast 0 0 o_D[2] o_D[3] o_D[4] o_D[5] EN Vdd 0 0 oc_0 oc_1 oc_2 oc_3 sdff_5_en
M1 EN N011 0 0 nmos_3p3 l=0.28u w=3u
M2 Vdd N011 EN Vdd pmos_3p3 l=0.28u w=9u
XX12 ck_fast y0_ff y1_ff y2_ff y3_ff y4_ff y5_ff Vdd N005 N006 N007 N008 N009 N010 dff_5

* block symbol definitions
.subckt 24x6muc PHI0 PHI0_0 PHI0_1 PHI0_2 PHI0_3 PHI0_4 PHI0_5 PHI1 PHI1_0 PHI1_1 PHI1_2 PHI1_3 PHI1_4 PHI1_5 PHI2 PHI2_0 PHI2_1 PHI2_2 PHI2_3 PHI2_4 PHI2_5 PHI3 PHI3_0 PHI3_1 PHI3_2 PHI3_3 PHI3_4 PHI3_5 Vdd Y0 Y1 Y2 Y3 Y4 Y5
XX1 PHI0 Vdd PHI0_0 PHI0_1 PHI0_2 PHI0_3 PHI0_4 PHI0_5 Y0 Y1 Y2 Y3 Y4 Y5 6x6tg
XX2 PHI1 Vdd PHI1_0 PHI1_1 PHI1_2 PHI1_3 PHI1_4 PHI1_5 Y0 Y1 Y2 Y3 Y4 Y5 6x6tg
XX3 PHI2 Vdd PHI2_0 PHI2_1 PHI2_2 PHI2_3 PHI2_4 PHI2_5 Y0 Y1 Y2 Y3 Y4 Y5 6x6tg
XX4 PHI3 Vdd PHI3_0 PHI3_1 PHI3_2 PHI3_3 PHI3_4 PHI3_5 Y0 Y1 Y2 Y3 Y4 Y5 6x6tg
.ends 24x6muc

.subckt decoder Q0 Q1 Vdd PHI_0 PHI_1 PHI_2 PHI_3
XX2 Q0 Q1 Vdd 0 PHI_0 nor2x1
XX3 Q0 Q1 Vdd N003 0 nand2x1
XX4 N003 Vdd PHI_3 0 invx1
XX5 Q0_BAR Q1 Vdd N002 0 nand2x1
XX6 N002 Vdd PHI_2 0 invx1
XX7 Q0 Q1_BAR Vdd N001 0 nand2x1
XX8 N001 Vdd PHI_1 0 invx1
XX9 Q0 Vdd Q0_BAR 0 invx1
XX10 Q1 Vdd Q1_BAR 0 invx1
.ends decoder

.subckt 2bcount CK Vdd Q0 Q1
XX1 Q1 Q0 Vdd N001 xorx1
XX2 CK N002 Vdd Q0 N002 sdff_improved
XX3 CK N001 Vdd Q1 NC_01 sdff_improved
.ends 2bcount

.subckt ramp i_clk i_rstb o_D[1] o_D[0] o_D[5] o_D[4] o_D[3] o_D[2]
A1[3] m[3] 0 i_clk 0 m_rst Db[5] n[3] 0 DFLOP Vhigh = 3.3 Vlow = 0 Trise = 'tt' Tfall = 'tt'
A1[2] m[2] 0 i_clk 0 m_rst Db[4] n[2] 0 DFLOP Vhigh = 3.3 Vlow = 0 Trise = 'tt' Tfall = 'tt'
A1[1] m[1] 0 i_clk 0 m_rst Db[3] n[1] 0 DFLOP Vhigh = 3.3 Vlow = 0 Trise = 'tt' Tfall = 'tt'
A1[0] m[0] 0 i_clk 0 m_rst Db[2] n[0] 0 DFLOP Vhigh = 3.3 Vlow = 0 Trise = 'tt' Tfall = 'tt'
V1[1] o_D[1] 0 0
V1[0] o_D[0] 0 0
A2 i_rstb 0 0 0 0 m_rst 0 0 BUF Vhigh = 3.3 Vlow = 0
XA3 n[0] N001 0 m_C[0] m[0] fa
XA4 n[1] 0 m_C[0] m_C[1] m[1] fa
XA5 n[2] 0 m_C[1] m_C[2] m[2] fa
XA6 n[3] 0 m_C[2] m_C[3] m[3] fa
A7 0 0 0 0 0 N001 0 0 BUF Vhigh = 3.3 Vlow = 0 Trise = 'tt' Tfall = 'tt'
A8[3] Db[5] 0 0 0 0 o_D[5] 0 0 BUF Vhigh = 3.3 Vlow = 0 Trise = 'tt' Tfall = 'tt'
A8[2] Db[4] 0 0 0 0 o_D[4] 0 0 BUF Vhigh = 3.3 Vlow = 0 Trise = 'tt' Tfall = 'tt'
A8[1] Db[3] 0 0 0 0 o_D[3] 0 0 BUF Vhigh = 3.3 Vlow = 0 Trise = 'tt' Tfall = 'tt'
A8[0] Db[2] 0 0 0 0 o_D[2] 0 0 BUF Vhigh = 3.3 Vlow = 0 Trise = 'tt' Tfall = 'tt'
.param tt = 50p
.ends ramp

.subckt pseudo_fir_cla_nocin Vdd Vee Xnew_0 Xnew_1 Xnew_2 Xnew_3 Xold_0 Xold_1 Xold_2 Xold_3 phi0_0 phi0_1 phi0_2 phi0_3 phi0_4 phi0_5 phi1_0 phi1_1 phi1_2 phi1_3 phi1_4 phi1_5 phi2_0 phi2_1 phi2_2 phi2_3 phi2_4 phi2_5 phi3_0 phi3_1 phi3_2 phi3_3 phi3_4 phi3_5
V1 phi0_0 Vee 0
V2 phi0_1 Vee 0
V3 phi0_2 Xnew_0 0
V4 phi0_3 Xnew_1 0
V5 phi0_4 Xnew_2 0
V6 phi0_5 Xnew_3 0
V7 phi2_0 Vee 0
XX2 phi2_1 phi2_2 phi2_3 phi2_4 phi2_5 Vee Xold_0 Xold_1 Xold_2 Xold_3 Vdd Vee phi1_5 phi1_0 phi1_1 phi1_2 phi1_3 phi1_4 pseudo-cla-5bit-nocin
XX3 phi2_1 phi2_2 phi2_3 phi2_4 phi2_5 Vee Xnew_0 Xnew_1 Xnew_2 Xnew_3 Vdd Vee phi3_5 phi3_0 phi3_1 phi3_2 phi3_3 phi3_4 pseudo-cla-5bit-nocin
XX1 Xold_0 Xold_1 Xold_2 Xold_3 Xnew_0 Xnew_1 Xnew_2 Xnew_3 Vdd Vee phi2_5 phi2_1 phi2_2 phi2_3 phi2_4 pseudo-cla-4bit-nocin
.ends pseudo_fir_cla_nocin

.subckt dff_ideal_5 ck d0 d1 d2 d3 d4 d5 q0 q1 q2 q3 q4 q5
A1 d0 0 ck 0 0 0 q0 0 DFLOP Vhigh = 3.3 Vlow = 0 Trise = 'tt' Tfall = 'tt'
A2 d1 0 ck 0 0 0 q1 0 DFLOP Vhigh = 3.3 Vlow = 0 Trise = 'tt' Tfall = 'tt'
A3 d2 0 ck 0 0 0 q2 0 DFLOP Vhigh = 3.3 Vlow = 0 Trise = 'tt' Tfall = 'tt'
A4 d3 0 ck 0 0 0 q3 0 DFLOP Vhigh = 3.3 Vlow = 0 Trise = 'tt' Tfall = 'tt'
A5 d4 0 ck 0 0 0 q4 0 DFLOP Vhigh = 3.3 Vlow = 0 Trise = 'tt' Tfall = 'tt'
A6 d5 0 ck 0 0 0 q5 0 DFLOP Vhigh = 3.3 Vlow = 0 Trise = 'tt' Tfall = 'tt'
.ends dff_ideal_5

.subckt nand2x1 A B Vdd X Vee
M1 N001 B Vee Vee nmos_3p3 l={L} w={Wn}
M3 Vdd A X Vdd pmos_3p3 l={L} w={Wp}
M4 Vdd B X Vdd pmos_3p3 l={L} w={Wp}
M2 X A N001 Vee nmos_3p3 l={L} w={Wn}
.param Wp=3u Wn=2u L=0.28u
.ends nand2x1

.subckt sdff_5_en ck d0 d1 d2 d3 d4 d5 EN vdd q0 q1 q2 q3 q4 q5
XX7 EN vdd d0 q0 N001 2x1_mux
XX8 EN vdd d1 q1 N002 2x1_mux
XX9 EN vdd d2 q2 N003 2x1_mux
XX10 EN vdd d3 q3 N004 2x1_mux
XX11 EN vdd d4 q4 N005 2x1_mux
XX12 EN vdd d5 q5 N006 2x1_mux
XX1 ck N001 vdd q0 NC_01 dff
XX2 ck N002 vdd q1 NC_02 dff
XX3 ck N003 vdd q2 NC_03 dff
XX4 ck N004 vdd q3 NC_04 dff
XX5 ck N005 vdd q4 NC_05 dff
XX6 ck N006 vdd q5 NC_06 dff
.ends sdff_5_en

.subckt dff_5 ck d0 d1 d2 d3 d4 d5 vdd q0 q1 q2 q3 q4 q5
XX1 ck d0 Vdd q0 NC_01 sdff_improved
XX2 ck d1 Vdd q1 NC_02 sdff_improved
XX3 ck d2 Vdd q2 NC_03 sdff_improved
XX4 ck d3 Vdd q3 NC_04 sdff_improved
XX5 ck d4 Vdd q4 NC_05 sdff_improved
XX6 ck d5 Vdd q5 NC_06 sdff_improved
.ends dff_5

.subckt 6x6tg A Vdd X0 X1 X2 X3 X4 X5 Y0 Y1 Y2 Y3 Y4 Y5
XX1 A A_BAR X0 Vdd Y0 tgate params: L=0.28u Wn=1u Wp=3u M=1
XX5 A Vdd A_BAR 0 invx1
XX2 A A_BAR X1 Vdd Y1 tgate params: L=0.28u Wn=1u Wp=3u M=1
XX3 A A_BAR X2 Vdd Y2 tgate params: L=0.28u Wn=1u Wp=3u M=1
XX6 A A_BAR X3 Vdd Y3 tgate params: L=0.28u Wn=1u Wp=3u M=1
XX7 A A_BAR X4 Vdd Y4 tgate params: L=0.28u Wn=1u Wp=3u M=1
XX8 A A_BAR X5 Vdd Y5 tgate params: L=0.28u Wn=1u Wp=3u M=1
.ends 6x6tg

.subckt nor2x1 A B Vdd Vee X
M1 X B Vee Vee nmos_3p3 l={L} w={Wn}
M3 N001 A X Vdd pmos_3p3 l={L} w={Wp}
M4 Vdd B N001 Vdd pmos_3p3 l={L} w={Wp}
M2 X A Vee Vee nmos_3p3 l={L} w={Wn}
.param Wp=6u Wn=1u L=0.28u
.ends nor2x1

.subckt invx1 A Vdd X Vee
M1 X A Vee Vee nmos_3p3 l={L} w={Wn}
M2 Vdd A X Vdd pmos_3p3 l={L} w={Wp}
.param Wp=3u Wn=1u L=0.28u
.ends invx1

.subckt xorx1 A B Vdd OUT
M1 A B_bar OUT 0 nmos_3p3 l='L' w='Wn' m='M'
M2 OUT B A Vdd pmos_3p3 l='L' w='Wp' m='M'
M3 OUT B A_bar 0 nmos_3p3 l='L' w='Wn' m='M'
M4 A_bar B_bar OUT Vdd pmos_3p3 l='L' w='Wp' m='M'
XX1 A Vdd A_bar 0 invx1
XX2 B Vdd B_bar 0 invx1
.param L=0.28u Wn=1u Wp=2u M=1
.ends xorx1

.subckt sdff_improved CK D Vdd Q Q_BAR
M1 Vdd CK N004 Vdd pmos_3p3 l={L} w={Wp1} m={Mp1}
M2 N007 N003 N008 0 nmos_3p3 l={L} w={Wn1} m={Mn1}
M3 N008 CK 0 0 nmos_3p3 l={L} w={Wn1} m={Mn1}
M4 N004 D N007 0 nmos_3p3 l={L} w={Wn1} m={Mn1}
M5 Vdd N004 Q Vdd pmos_3p3 l={L} w={Wp3} m={Mp3}
M6 Q N006 N011 0 nmos_3p3 l={L} w={Wn3} m={Mn3}
M7 N011 N004 0 0 nmos_3p3 l={L} w={Wn3} m={Mn3}
XX4 N009 Vdd N006 0 invx1
XX5 CK Vdd N009 0 invx1
XX1 N006 Vdd N003 0 invx1
M8 N002 N003 N004 Vdd pmos_3p3 l={L} w={Wp2} m={Mp2}
M9 Vdd N001 N002 Vdd pmos_3p3 l={L} w={Wp2} m={Mp2}
M10 N004 N001 N008 0 nmos_3p3 l={L} w={Wn2} m={Mn2}
XX2 N004 Vdd N001 0 invx1
M11 Q N009 N010 0 nmos_3p3 l={L} w={Wn4} m={Mn4}
M12 N005 N006 Q Vdd pmos_3p3 l={L} w={Wp4} m={Mp4}
M13 Vdd Q_BAR N005 Vdd pmos_3p3 l={L} w={Wp4} m={Mp4}
XX3 Q Vdd Q_BAR 0 invx1
M14 N010 Q_BAR 0 0 nmos_3p3 l={L} w={Wn4} m={Mn4}
.param Wp1=3u Wn1=3u L=0.28u Mn1=1 Mp1=1
.param Wp2=2u Wn2=3u Mp2=1 Mn2=1
.param Wp4=9u Wn4=3u Mp4=1 Mn4=1
.param Wp3=9u Wn3=3u Mp3=1 Mn3=1
.ends sdff_improved

.subckt fa i_A i_B i_C o_C o_S
B1 o_C 0 V = ((V(i_A)&V(i_B)) | (V(i_B)&V(i_C)) | (V(i_A)&V(i_C)))*3.3
B2 o_S 0 V=((V(i_A)^V(i_B))^V(i_C))*3.3
.ends fa

.subckt pseudo-cla-5bit-nocin A_0 A_1 A_2 A_3 A_4 B_0 B_1 B_2 B_3 B_4 Vdd Vee Co_4 S0 S1 S2 S3 S4
XX34 N013 Vdd N014 Vee invx1
XX35 N007 Vdd N008 Vee invx1
XX36 N005 Vdd N006 Vee invx1
XX37 N002 Vdd S2 Vee invx1
XX38 N003 Vdd S3 Vee invx1
XX39 N001 Vdd S1 Vee invx1
XX42 P_2 G_1 Vdd N013 Vee nand2x1
XX43 P_3 G_2 Vdd N007 Vee nand2x1
XX44 P_1 Co_0 Vdd N005 Vee nand2x1
XX47 P_1 Co_0 Vdd Vee N001 xnor2x1
XX48 P_2 Co_1 Vdd Vee N002 xnor2x1
XX49 P_3 Co_2 Vdd Vee N003 xnor2x1
XX1 A_0 B_0 Vdd Vee Co_0 P_0 pg
XX2 A_1 B_1 Vdd Vee G_1 P_1 pg
XX3 A_2 B_2 Vdd Vee G_2 P_2 pg
XX4 A_3 B_3 Vdd Vee G_3 P_3 pg
