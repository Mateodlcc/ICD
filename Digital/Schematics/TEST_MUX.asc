TEXT -1024 464 Left 2 !* Changes in PHI 0 DATA\n.measure tran tmux_data_phi0_rise TRIG V(phi) VAL=1.65 RISE=1 TARG V(y0) VAL=1.65 RISE=1\n.measure tran tmux_data_phi0_fall TRIG V(phi) VAL=1.65 FALL=1 TARG V(y0) VAL=1.65 FALL=1\n \n* Changes in PHI 1 DATA\n.measure tran tmux_data_phi1_rise TRIG V(phi) VAL=1.65 RISE=1 TARG V(y0) VAL=1.65 RISE=1\n.measure tran tmux_data_phi1_fall TRIG V(phi) VAL=1.65 FALL=1 TARG V(y0) VAL=1.65 FALL=1\n \n* Changes in PHI 2 DATA\n.measure tran tmux_data_phi2_rise TRIG V(phi) VAL=1.65 RISE=1 TARG V(y0) VAL=1.65 RISE=1\n.measure tran tmux_data_phi2_fall TRIG V(phi) VAL=1.65 FALL=1 TARG V(y0) VAL=1.65 FALL=1\n \n* Changes in PHI 3 DATA\n.measure tran tmux_data_phi3_rise TRIG V(phi) VAL=1.65 RISE=1 TARG V(y0) VAL=1.65 RISE=1\n.measure tran tmux_data_phi3_fall TRIG V(phi) VAL=1.65 FALL=1 TARG V(y0) VAL=1.65 FALL=1
TEXT -2448 464 Left 2 !* Phase transitions (selector changes)\n* From 00 -> 01\n.measure tran tmux_sel01_rise TRIG V(q0) VAL=1.65 RISE=1 TARG V(y5) VAL=1.65 RISE=1\n.measure tran tmux_sel01_fall TRIG V(q0) VAL=1.65 RISE=1 TARG V(y5) VAL=1.65 FALL=1\n \n* From 01 -> 10\n.measure tran tmux_sel12_rise TRIG V(q1) VAL=1.65 RISE=1 TARG V(y5) VAL=1.65 RISE=1\n.measure tran tmux_sel12_fall TRIG V(q1) VAL=1.65 RISE=1 TARG V(y5) VAL=1.65 FALL=1\n \n* From 10 -> 11\n.measure tran tmux_sel23_rise TRIG V(q0) VAL=1.65 RISE=1 TARG V(y5) VAL=1.65 RISE=1\n.measure tran tmux_sel23_fall TRIG V(q0) VAL=1.65 RISE=1 TARG V(y5) VAL=1.65 FALL=1\n \n* From 11 -> 00\n.measure tran tmux_sel30_rise TRIG V(q0) VAL=1.65 FALL=1 TARG V(y5) VAL=1.65 RISE=1\n.measure tran tmux_sel30_fall TRIG V(q0) VAL=1.65 FALL=1 TARG V(y5) VAL=1.65 FALL=1
