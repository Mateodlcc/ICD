.subckt nor2x1 A B Vdd Vee X
M1 X B Vee Vee nmos_3p3 l={L} w={Wn}
M3 N001 A X Vdd pmos_3p3 l={L} w={Wp}
M4 Vdd B N001 Vdd pmos_3p3 l={L} w={Wp}
M2 X A Vee Vee nmos_3p3 l={L} w={Wn}
.param Wp=6u Wn=1u L=0.28u
.ends nor2x1

.subckt invx1 A Vdd X Vee
M1 X A Vee Vee nmos_3p3 l={L} w={Wn}
M2 Vdd A X Vdd pmos_3p3 l={L} w={Wp}
.param Wp=3u Wn=1u L=0.28u
.ends invx1

.subckt tgate A A_bar IN Vdd OUT
M1 IN A OUT 0 nmos_3p3 l='L' w='Wn' m='M'
M2 OUT A_bar IN Vdd pmos_3p3 l='L' w='Wp' m='M'
.param L=0.28u Wn=1u Wp=3u M=1
.ends tgate

.model NMOS NMOS
.model PMOS PMOS
.lib C:\Users\Vicente\AppData\Local\LTspice\lib\cmp\standard.mos
.inc ..\..\gf180\cmos_tt.txt
.param vid=0 Vicm=1.65
.param Cs=20f Cf=91f
* TV SIMULATION
* TI SIMULATION
.ac dec 1000 1 10G
.meas AC fc WHEN mag(((V(tv_num)/V(tv_den))*(V(ti_num)/V(ti_den))-1)/((V(tv_num)/V(tv_den))+(V(ti_num)/V(ti_den))+2))=1 FALL=1
.meas AC phT FIND (((V(tv_num)/V(tv_den))*(V(ti_num)/V(ti_den))-1)/((V(tv_num)/V(tv_den))+(V(ti_num)/V(ti_den))+2)) WHEN mag(((V(tv_num)/V(tv_den))*(V(ti_num)/V(ti_den))-1)/((V(tv_num)/V(tv_den))+(V(ti_num)/V(ti_den))+2))=1 FALL=1
.meas AC pm PARAM 180+phT
* (((V(tv_num)/V(tv_den))*(V(ti_num)/V(ti_den))-1)/((V(tv_num)/V(tv_den))+(V(ti_num)/V(ti_den))+2))
.backanno
.end
