.subckt diff_looptest xp xm yp ym Tv_Num Tv_Den Ti_Num Ti_Den
Vyp middp yp AC 'Av'
Vxm middm xm AC 'Av'
Vxp middp xp 0
Vym middm ym 0
I1 middm middp AC 'Ai'
B1 Tv_den 0 V='V(xp)-V(xm)'
B2 Ti_den 0 V='I(Vxp)-I(Vxm)'
B3 Tv_num 0 V='V(ym)-V(yp)'
B4 Ti_num 0 V='I(Vyp)-I(Vym)'
.ends diff_looptest

.subckt ota_lp CK_MASTER Vdd Vim Vip Vocm_target Vom Vop
